PORT=5000
NODE_ENV=development

# Supabase / production: use the connection string from Supabase dashboard
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Local development fallback (when DATABASE_URL is not set)
DB_USER=postgres
DB_HOST=127.0.0.1
DB_NAME=talentlens_db
DB_PASSWORD=your_postgres_password
DB_PORT=5432

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# Frontend URL for OAuth redirects and CORS (your Vercel URL in production)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth (callback must point to this backend, not the frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

GEMINI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=
